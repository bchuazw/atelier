# Copy to .env.local and fill in. Never commit .env.local.
ANTHROPIC_API_KEY=sk-ant-...

# MiniMax (image + short-video generation for the hero-media flow).
# Leave empty to use the labeled-mock fallback (full hero-media flow still
# works in dev; the resulting asset is a placeholder SVG that says
# "[minimax-mock] Set MINIMAX_API_KEY to render real imagery.").
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io

# Optional overrides
ATELIER_DB_URL=sqlite+aiosqlite:///./atelier.db
ATELIER_ASSETS_DIR=../../assets
ATELIER_SANDBOX_PORT=4100
ATELIER_API_PORT=8000
ATELIER_WEB_PORT=3000

# Storage selection. Local dev uses sandbox-server reading from disk; hosted
# uses Supabase Storage so the frontend can iframe the public bucket URLs.
ATELIER_STORAGE_MODE=local            # local | supabase
SUPABASE_URL=                          # https://<proj>.supabase.co
SUPABASE_SERVICE_KEY=                  # service_role key (NOT anon)
SUPABASE_BUCKET=variants

# Hosted CORS — comma-separated. Local origins are always allowed.
ATELIER_ALLOWED_ORIGINS=               # e.g., https://atelier-web.onrender.com

# Sandbox-server public URL (hosted only). In hosted mode the sandbox-server
# runs as a third Render service in PROXY mode, fetching from Supabase Storage
# and rewriting Content-Type (Supabase forces text/plain on HTML which would
# otherwise break iframe rendering). Variant iframe URLs resolve through here.
ATELIER_SANDBOX_PUBLIC_URL=            # e.g., https://atelier-sandbox.onrender.com
ATELIER_SANDBOX_MODE=local             # local | proxy (local for dev; proxy for hosted)
